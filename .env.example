# Lark CLI
LARK_CLI_BIN=/opt/homebrew/bin/lark-cli
LARK_HOME=
TARGET_CHAT_ID=

# OpenAI API
OPENAI_API_KEY=
OPENAI_API_KEY_KEYCHAIN_SERVICE=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_MODEL=gpt-4.1-mini
OPENAI_MODEL_CANDIDATES=
OPENAI_API_URL=https://api.openai.com/v1/responses

# Bot identity
BOT_OPEN_ID=
BOT_MENTION_PATTERNS=

# Tavily Search (https://tavily.com — 1000 free/month)
TAVILY_API_KEY=

# Runtime
LOG_LEVEL=info
DB_PATH=./data/persona.db
PERSONA_CONFIG=./persona.yaml
