{
  "name": "persona-bot",
  "version": "0.1.0",
  "description": "Persona-Driven Ontological Chatbot Entity for Lark/Feishu",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/config/*.yaml dist/config/",
    "start": "node dist/index.js",
    "restart": "npm run build && node dist/index.js",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop persona-bot && pm2 delete persona-bot",
    "pm2:restart": "npm run build && pm2 restart persona-bot",
    "pm2:logs": "pm2 logs persona-bot",
    "pm2:status": "pm2 show persona-bot",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/utils/db-init.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}